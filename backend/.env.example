# ────────────────────────────────────────────
#  TrincoGuide Backend — Environment Variables
# ────────────────────────────────────────────
# Copy this file to  .env  and fill in values.
#
# OPTION A — Use a Service Account JSON file
#   Place your service-account-key.json in  backend/config/
#   then set the path below:
#
# GOOGLE_APPLICATION_CREDENTIALS=./config/serviceAccountKey.json
#
# OPTION B — Use individual env vars (no JSON file needed)
#   Fill in all FIREBASE_* vars below:

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Storage bucket (for image uploads)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Server
PORT=5000
NODE_ENV=development

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# Email notifications
# Gmail works with only SMTP_USER + SMTP_PASS when SMTP_HOST is omitted.
# Use a Gmail App Password, not your normal Gmail password.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password-or-app-password
MAIL_FROM="TrincoGuide <your-email@example.com>"
